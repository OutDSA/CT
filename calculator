history=[]
while True:
    task = input("enter math / 'h'->history / 'q'->quit:").lower()
    if task == 'q':
        break
    elif task == 'h':
        print("\n".join(history) if history else "empty")
    else:
        try:
            result = eval(task)
            entry = f"{task} = {result}"
            print(f"result->{result}")
            history.append(entry)
        except:
            print("invalid match")
